# Barchart session credentials
# Only needed if the automatic Firefox/Safari cookie reader fails.
#
# How to get these values:
#   1. Log into barchart.com in Firefox or Safari
#   2. Open DevTools (F12) → Network tab
#   3. Click any request to proxies/core-api
#   4. Copy the Cookie and x-xsrf-token header values below

BARCHART_COOKIE=
BARCHART_XSRF_TOKEN=
